# ChromeBridge 配置示例
# 复制此文件为 config.env 并根据需要修改

# 是否启用调试模式（打印详细日志）
# 默认值: false
DebugMode=false

# ========== Puppeteer 自动化引擎配置 ==========
# 以下配置用于 Agent 主动启动浏览器的场景（launch_browser 命令）
# 如果不使用 Puppeteer 自动化功能，可以忽略这些配置

# Chrome/Edge 可执行文件路径（留空自动检测）
# Windows 示例: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS 示例: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux 示例: /usr/bin/google-chrome
ChromePath=

# Chrome User Data 目录路径（用于继承已登录状态）
# 留空将使用系统默认路径
# Windows 默认: %LOCALAPPDATA%\Google\Chrome\User Data
# macOS 默认: ~/Library/Application Support/Google/Chrome
# Linux 默认: ~/.config/google-chrome
# 
# ⚠️ 重要提示：
# 1. 如果你日常使用的 Chrome 浏览器正在运行，Puppeteer 无法共用同一个 Profile
#    解决方案：在 Chrome 中创建一个新的 Profile（如 VCPAutomate），
#    然后将 ChromeProfileName 设为该 Profile 名称
# 2. 使用用户 Profile 可以继承所有已登录的网站状态（如抖音、B站等）
ChromeProfilePath=

# Chrome Profile 名称
# 如 Default / Profile 1 / Profile 2
# 建议创建一个专用 Profile（如 VCPAutomate）避免与日常浏览冲突
# 默认值: Default
ChromeProfileName=Default
