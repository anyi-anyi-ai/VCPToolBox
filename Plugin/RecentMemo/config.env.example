# RecentMemo Plugin Configuration (V2.2 Stable)

# [核心逻辑]
# 滑动窗口保留的消息条数 (超过此数量将移入 .Arc 缓存)
RecentMemo_MaxRounds=50

# 归档触发阈值 (当 .Arc 缓存达到此条数时，生成独立的日期归档文件)
RecentMemo_ArchiveThreshold=100

# [AI 总结配置] - 仅在使用 aisum 模式时生效
API_Key=sk-xxxx
API_URL=http://127.0.0.1:3000
RecentMemo_Model=gemini-3-flash

# [角色别名映射] - 可选，用于自定义历史中显示的角色名
# 格式: RecentMemo_Role_{AgentName}_User / Assistant
# RecentMemo_Role_Y_User=述
# RecentMemo_Role_Y_Assistant=荧
