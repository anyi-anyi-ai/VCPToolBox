# ModelScope API-Inference Access Token
# Get from: https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY=

# Default AIGC model id
MODELSCOPE_DEFAULT_MODEL=Qwen/Qwen-Image

# Default image generation parameters
MODELSCOPE_DEFAULT_SIZE=1024x1024
MODELSCOPE_DEFAULT_STEPS=30
MODELSCOPE_DEFAULT_GUIDANCE=3.5

# Output directory (relative to VCPToolBox root)
MODELSCOPE_OUTPUT_DIR=image/modelscope_gen

# Polling behavior
MODELSCOPE_POLL_INTERVAL_SEC=5
MODELSCOPE_TIMEOUT_SEC=120
