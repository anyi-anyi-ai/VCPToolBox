# QQ群聊消息读取器配置
# 通过 lldb 从 QQ 进程提取的 16 字节数据库解密密钥
QQ_DB_KEY=your_16_byte_key_here

# NTQQ 数据库目录路径（包含 nt_msg.db 和 profile_info.db）
# macOS 路径示例：~/Library/Containers/com.tencent.qq/Data/Library/Application Support/QQ/nt_qq_HASH/nt_db
QQ_DB_DIR=/path/to/nt_db

# sqlcipher 可执行文件路径
SQLCIPHER_PATH=/opt/homebrew/opt/sqlcipher/bin/sqlcipher

# 默认查询最近多少小时的消息
DEFAULT_HOURS=24

# 单次查询最大消息数
MAX_MESSAGES=500

# 关注配置（可选）
# 特别关注的群号（逗号分隔）
WATCH_GROUP=
# 特别关注的QQ号（逗号分隔），这些人的消息会被标记为 [★关注]
WATCH_QQ=
# 关注的关键词（逗号分隔），包含这些词的消息会被标记为 [★话题]
WATCH_KEYWORDS=AI,大模型,LLM,GPT,Claude,Gemini,VCP,免费,token,API,密钥,白嫖,福利,开源
